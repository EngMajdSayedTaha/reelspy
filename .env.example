# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic (script generation)
ANTHROPIC_API_KEY=

# Instagram / Meta Graph API
META_APP_ID=
META_IG_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=

# Meta rate-limit guard (optional — sensible defaults shown).
# Business Discovery is rate-limited per Meta APP (200 × daily-active-users per
# rolling hour), a pool SHARED by every connected user. These keep app-wide
# usage safely under that ceiling. See supabase/migrations/20260610_meta_rate_limit.sql.
# Effective app-wide hourly call budget (keep under Meta's ~200/hour floor):
META_HOURLY_BUDGET=160
# Max Business Discovery calls one user may spend per hour:
META_USER_HOURLY_BUDGET=80
# Circuit-breaker cooldown when Meta gives no explicit regain time (seconds):
META_THROTTLE_COOLDOWN_SECONDS=3600
# Brief back-off when usage crosses the safety line but isn't a hard block (seconds):
META_SOFT_COOLDOWN_SECONDS=300
# App-usage % at/above which we proactively back off (Meta hard-throttles at 100):
META_SAFE_USAGE_PCT=90

# Reel transcription: yt-dlp extracts the reel's media URL, then Whisper
# transcribes it. The feature degrades gracefully if unset.
# Whisper engine (required for transcripts to work — Groq has a free tier):
GROQ_API_KEY=
HF_API_TOKEN=
# Optional: base64-encoded Netscape cookies.txt for Instagram (many reels need it).
#   base64 -w0 cookies.txt
YTDLP_COOKIES_B64=
# Optional: override the yt-dlp binary path (defaults to the bundled bin/yt-dlp_linux).
YTDLP_BIN=
