# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic (script generation)
ANTHROPIC_API_KEY=

# Instagram / Meta Graph API
META_APP_ID=
META_IG_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=

# Reel transcription: yt-dlp extracts the reel's media URL, then Whisper
# transcribes it. The feature degrades gracefully if unset.
# Whisper engine (required for transcripts to work — Groq has a free tier):
GROQ_API_KEY=
HF_API_TOKEN=
# Optional: base64-encoded Netscape cookies.txt for Instagram (many reels need it).
#   base64 -w0 cookies.txt
YTDLP_COOKIES_B64=
# Optional: override the yt-dlp binary path (defaults to the bundled bin/yt-dlp_linux).
YTDLP_BIN=
