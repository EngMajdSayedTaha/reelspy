# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY (cron jobs + global snapshot cache). Bypasses
# RLS, so never expose it to the browser. Found in Supabase → Project Settings → API.
SUPABASE_SERVICE_ROLE_KEY=

# Secret guarding the /api/cron/* endpoints. Vercel Cron sends it as a Bearer
# token; without it the cron routes refuse to run. Use a long random string.
CRON_SECRET=

# Anthropic (script generation)
ANTHROPIC_API_KEY=

# UI: how long toast notifications stay on screen (ms). Default 5000.
NEXT_PUBLIC_TOAST_DURATION_MS=5000

# Instagram / Meta Graph API
META_APP_ID=
META_IG_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=

# Auto-Reply module (comment → public reply + DM). Random string you also paste
# as the "Verify Token" when configuring the webhook in the Meta App Dashboard
# (Webhooks → Instagram → callback https://<domain>/api/ig/webhooks).
# Full setup walkthrough: docs/auto-reply-setup.md
META_WEBHOOK_VERIFY_TOKEN=

# Meta rate-limit guard (optional — sensible defaults shown).
# Business Discovery is rate-limited per Meta APP (200 × daily-active-users per
# rolling hour), a pool SHARED by every connected user. These keep app-wide
# usage safely under that ceiling. See supabase/migrations/20260610_meta_rate_limit.sql.
# Effective app-wide hourly call budget (keep under Meta's ~200/hour floor):
META_HOURLY_BUDGET=160
# Max Business Discovery calls one user may spend per hour:
META_USER_HOURLY_BUDGET=80
# Circuit-breaker cooldown when Meta gives no explicit regain time (seconds):
META_THROTTLE_COOLDOWN_SECONDS=3600
# Brief back-off when usage crosses the safety line but isn't a hard block (seconds):
META_SOFT_COOLDOWN_SECONDS=300
# App-usage % at/above which we proactively back off (Meta hard-throttles at 100):
META_SAFE_USAGE_PCT=90

# Global snapshot cache (the dedup layer). Each public account is fetched from
# Meta at most once per TTL and shared by every user who tracks it.
# How long a cached account's reels stay fresh (seconds, default 6h):
SNAPSHOT_TTL_SECONDS=21600
# Max reels stored per account snapshot:
SNAPSHOT_MAX_REELS=25
# Max accounts the cron worker refreshes per run (keeps runs within time + budget):
SNAPSHOT_REFRESH_BATCH=50
# Refresh tokens this many days before they expire:
TOKEN_REFRESH_WINDOW_DAYS=7

# ── Publishing module (cross-post to IG, FB, TikTok, YouTube) ─────────────────
# Instagram Reels + Facebook Page posting reuse the META_* vars above. The IG
# OAuth scope list adds instagram_content_publish + pages_manage_posts (override
# with META_IG_SCOPES if you set it explicitly).
#
# TikTok Content Posting API (https://developers.tiktok.com). Redirect URI must
# match the one registered in the TikTok developer portal.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=
# Only set true AFTER the TikTok app audit passes — otherwise posts must be
# SELF_ONLY (private). Leave unset to force private posts.
TIKTOK_ALLOW_PUBLIC=
#
# YouTube Data API v3 (Google Cloud OAuth client). Scope: youtube.upload.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=
# Only set true AFTER the YouTube API audit passes — otherwise uploads stay
# private. Leave unset to force private uploads.
YOUTUBE_ALLOW_PUBLIC=
# Max scheduled posts the publish-due cron processes per run (default 10):
PUBLISH_DUE_BATCH=10

# Reel transcription: yt-dlp extracts the reel's media URL, then Whisper
# transcribes it. The feature degrades gracefully if unset.
# Whisper engine (required for transcripts to work — Groq has a free tier):
GROQ_API_KEY=
HF_API_TOKEN=
# Optional: base64-encoded Netscape cookies.txt for Instagram (many reels need it).
#   base64 -w0 cookies.txt
YTDLP_COOKIES_B64=
# Optional: override the yt-dlp binary path (defaults to the bundled bin/yt-dlp_linux).
YTDLP_BIN=
